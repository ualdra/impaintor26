# Copia este archivo como .env y ajusta los valores para tu entorno.
# El archivo .env real está en .gitignore y nunca debe commitearse.

# PostgreSQL
POSTGRES_USER=impaintor
POSTGRES_PASSWORD=impaintor_pass

# RabbitMQ
RABBITMQ_USER=impaintor
RABBITMQ_PASS=impaintor

# JWT — cámbialo en producción, mínimo 32 caracteres
JWT_SECRET=dev-secret-change-me-dev-secret-change-me-dev-secret
